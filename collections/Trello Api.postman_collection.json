              "});\r",
              "\r",
              "pm.test(\"Creat board name\", function () {\r",
              "    pm.expect(jsonData.name).to.eql(\"board\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response has 'name' field\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"name\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response has 'desc' field\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"desc\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response has 'url' field\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"url\");\r",
              "});\r",
              "\r",
              "pm.test(\"Permission level is private\", function () {\r",
              "    pm.expect(jsonData.prefs.permissionLevel).to.eql(\"private\");\r",
              "});"
